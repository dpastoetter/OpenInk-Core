{
  "name": "browseros",
  "version": "1.0.0",
  "type": "module",
  "repository": "https://github.com/dpastoetter/OpenInk-WebOS.git",
  "homepage": "https://github.com/dpastoetter/OpenInk-WebOS#readme",
  "scripts": {
    "dev": "node scripts/copy-stockfish.mjs && vite --host",
    "build": "node scripts/copy-stockfish.mjs && tsc -b && vite build --config vite.legacy-single.config.ts && node scripts/generate-legacy-html.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "screenshot": "node scripts/screenshot-legacy.mjs",
    "push:github": "./scripts/push-to-github.sh"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "preact": "^10.19.2",
    "regenerator-runtime": "^0.14.1",
    "stockfish.js": "^10.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^9.15.0",
    "@preact/preset-vite": "^2.8.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-legacy": "^5.4.0",
    "eslint": "^9.15.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^15.12.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.58.2",
    "terser": "^5.36.0",
    "typescript": "~5.3.0",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^1.2.0"
  }
}
